# Ollama (Qwen3 14B)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:14b
LLM_NUM_CTX=16384

# Embedding / Reranker (run on CPU to spare 16GB VRAM for the LLM)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu

# Qdrant
QDRANT_URL=http://localhost:6333

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=codelens123

# Local data dir (sqlite state, etc.)
DATA_DIR=./data

# Retrieval
RETRIEVAL_TOP_K=50
RERANK_TOP_N=8
